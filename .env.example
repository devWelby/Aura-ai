# -------------------------------------------------------
# COPIE ESTE ARQUIVO PARA .env e preencha os valores
#   cp .env.example .env
# NUNCA commite o .env com valores reais!
# -------------------------------------------------------

# -------------------------------------------------------
# BANCO DE DADOS
# -------------------------------------------------------
DB_HOST=localhost
DB_NAME=analista_financeiro_db
DB_USER=root
DB_PASS=

# -------------------------------------------------------
# GOOGLE GEMINI API
# Crie sua chave em: https://aistudio.google.com/app/apikey
# -------------------------------------------------------
GEMINI_API_KEY=sua_chave_gemini_aqui

# -------------------------------------------------------
# STRIPE
# Painel: https://dashboard.stripe.com/apikeys
# Use chaves test (sk_test_...) em desenvolvimento e
# chaves live (sk_live_...) apenas em producao.
# -------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_SUA_CHAVE_SECRETA_AQUI
STRIPE_PRICE_ID=price_SEU_ID_DE_PRECO_AQUI

# Webhook: https://dashboard.stripe.com/webhooks
# Execute `stripe listen --forward-to localhost/webhook.php`
# para obter a chave local em desenvolvimento.
STRIPE_WEBHOOK_SECRET=whsec_SUA_CHAVE_WEBHOOK_AQUI

# -------------------------------------------------------
# SEGURANCA DE COOKIES
# Gere com: php -r "echo bin2hex(random_bytes(32));"
# -------------------------------------------------------
COOKIE_SIGNING_SECRET=gere_um_valor_aleatorio_longo_aqui

# -------------------------------------------------------
# AMBIENTE (development | production)
# Em producao, erros PHP devem ser suprimidos.
# -------------------------------------------------------
APP_ENV=development

# -------------------------------------------------------
# RESEND (verificacao de e-mail)
# -------------------------------------------------------
RESEND_API_KEY=re_SUA_CHAVE_RESEND_AQUI
URL_BASE=http://localhost/analista-financeiro
