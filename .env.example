# -------------------------------------------------------
# COPIE ESTE ARQUIVO PARA .env e preencha os valores
#   cp .env.example .env
# NUNCA commite o .env com valores reais!
# -------------------------------------------------------

# -------------------------------------------------------
# BANCO DE DADOS
# -------------------------------------------------------
# Provider de dados usado pelo projeto (ex: mysql | firestore)
# Mantenha mysql no estado atual; use firestore ao testar migracao.
DB_PROVIDER=mysql

DB_HOST=localhost
DB_PORT=3306
DB_NAME=analista_financeiro_db
DB_USER=root
DB_PASS=

# -------------------------------------------------------
# FIREBASE (preparacao para migracao de banco)
# Use apenas UMA das opcoes de credencial abaixo.
# 1) FIREBASE_SERVICE_ACCOUNT_PATH para arquivo JSON local
# 2) FIREBASE_SERVICE_ACCOUNT_JSON para JSON inline (CI/CD)
# -------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=

# -------------------------------------------------------
# APP NODE.JS
# -------------------------------------------------------
PORT=3000
APP_URL=http://localhost:3000
URL_BASE=http://localhost:3000
SESSION_SECRET=troque_por_um_segredo_longo

# APP_URL e usada pelo healthcheck e links de retorno.

# -------------------------------------------------------
# GOOGLE GEMINI API
# Crie sua chave em: https://aistudio.google.com/app/apikey
# -------------------------------------------------------
GEMINI_API_KEY=sua_chave_gemini_aqui

# -------------------------------------------------------
# STRIPE
# Painel: https://dashboard.stripe.com/apikeys
# Use chaves test (sk_test_...) em desenvolvimento e
# chaves live (sk_live_...) apenas em producao.
# -------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_SUA_CHAVE_SECRETA_AQUI
STRIPE_PRICE_ID=price_SEU_ID_DE_PRECO_AQUI

# Webhook: https://dashboard.stripe.com/webhooks
# Execute `stripe listen --forward-to localhost:3000/webhook.php`
# para obter a chave local em desenvolvimento.
STRIPE_WEBHOOK_SECRET=whsec_SUA_CHAVE_WEBHOOK_AQUI

# -------------------------------------------------------
# SEGURANCA DE COOKIES
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -------------------------------------------------------
COOKIE_SIGNING_SECRET=gere_um_valor_aleatorio_longo_aqui

# -------------------------------------------------------
# AMBIENTE (development | production)
# Em producao, usar HTTPS e APP_ENV=production.
# -------------------------------------------------------
APP_ENV=development

# -------------------------------------------------------
# RESEND (verificacao de e-mail)
# -------------------------------------------------------
RESEND_API_KEY=re_SUA_CHAVE_RESEND_AQUI

# -------------------------------------------------------
# GOOGLE OAUTH
# -------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/callback_google.php

# -------------------------------------------------------
# GOOGLE ADSENSE (MONETIZACAO)
# -------------------------------------------------------
# Ative apenas quando tiver conta aprovada no AdSense.
ADSENSE_ENABLED=0

# Exemplo: ca-pub-1234567890123456
ADSENSE_CLIENT_ID=ca-pub-SEU_CLIENT_ID

# IDs dos blocos criados no painel do AdSense (numerico)
ADSENSE_SLOT_HEADER=1234567890
ADSENSE_SLOT_INCONTENT=2345678901
ADSENSE_SLOT_FOOTER=3456789012

# Esconde anuncios para usuarios com plano pro
ADSENSE_HIDE_FOR_PRO=1
