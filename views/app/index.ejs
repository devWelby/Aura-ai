<%- include('../partials/header') %>

<div class="container">
  <div class="top-bar">
    <div>
      <span style="font-size: 1.2rem; font-weight: bold;">Ola, <%= nomeUsuario %></span>
      <% if (planoUsuario !== 'visitante') { %>
        <span class="chip chip-primary" style="margin-left: 8px;">Plano <%= planoUsuario %></span>
      <% } %>
    </div>
    <div style="font-size: 13px; color: var(--text-muted);">Painel rapido</div>
  </div>

  <div style="text-align: center; margin-bottom: 20px;">
    <h2>Analise Financeira Inteligente</h2>
    <p style="color: var(--text-muted); margin-bottom: 10px;">Envie seu extrato para gerar diagnostico, alertas e recomendacoes praticas.</p>
  </div>

  <div class="grid-3" style="margin-bottom: 18px;">
    <div class="soft-card soft-card-muted">
      <div class="kpi-label">Formato</div>
      <div class="kpi-value" style="font-size: 16px;">PDF, CSV, XLSX</div>
    </div>
    <div class="soft-card soft-card-muted">
      <div class="kpi-label">Limite de arquivo</div>
      <div class="kpi-value" style="font-size: 16px;">5 MB</div>
    </div>
    <div class="soft-card soft-card-muted">
      <div class="kpi-label">Resposta</div>
      <div class="kpi-value" style="font-size: 16px;">Relatorio imediato</div>
    </div>
  </div>

  <% if (!isLogged || planoUsuario === 'gratis') { %>
    <% const percentualUsado = (analisesUsadas / limiteGratuito) * 100; %>
    <div class="soft-card" style="margin-bottom: 20px;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; flex-wrap: wrap; gap: 8px;">
        <span style="font-weight: 700; color: var(--text-main); font-size: 14px;">Analises Disponiveis no mes</span>
        <span class="chip chip-primary"><%= analisesRestantes %>/<%= limiteGratuito %></span>
      </div>
      <div class="progress-track" data-progress="<%= Math.max(0, Math.min(100, percentualUsado)) %>">
        <div class="progress-fill"></div>
      </div>
      <div style="margin-top: 10px; font-size: 13px; color: var(--text-muted);">
        <% if (analisesRestantes > 0) { %>
          Use com estrategia: envie extratos completos para aproveitar melhor cada analise.
        <% } else { %>
          Seu limite gratuito terminou. Assine para analises ilimitadas.
        <% } %>
      </div>
    </div>
  <% } else if (isLogged && planoUsuario === 'pro') { %>
    <div class="soft-card pro-banner" style="margin-bottom: 20px;">
      <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
        <div>
          <div class="pro-banner-title" style="font-weight: 700;">Plano Pro ativo</div>
          <div class="pro-banner-text" style="font-size: 13px;">Analises ilimitadas e historico completo.</div>
        </div>
        <span class="chip chip-success">Ilimitado</span>
      </div>
    </div>
  <% } %>

  <% if (isLogged) { %>
    <div class="soft-card" style="margin-bottom: 20px;">
      <p class="section-title">Meta de Economia Mensal</p>

      <% if (metaSalva) { %>
        <div class="msg sucesso" style="margin-bottom: 12px;">Meta de economia atualizada com sucesso.</div>
      <% } %>

      <div class="grid-2" style="align-items: start;">
        <form method="POST" action="<%= appUrl %>/dashboard/meta-economia" style="margin: 0;">
          <input type="hidden" name="csrf_token" value="<%= csrfToken %>">
          <label for="metaEconomia">Defina sua meta (R$)</label>
          <input id="metaEconomia" type="number" min="0" step="0.01" name="meta_economia_mensal" value="<%= Number(metaEconomiaMensal || 0).toFixed(2) %>">
          <button type="submit" class="btn" style="width: auto;">Salvar Meta</button>
        </form>

        <div class="soft-card soft-card-muted">
          <div class="kpi-label">Progresso no mes atual</div>
          <div class="kpi-value" style="font-size: 18px; margin-bottom: 8px;">R$ <%= Number(progressoMeta.saldo || 0).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>
          <% if (Number(metaEconomiaMensal || 0) > 0) { %>
            <div class="progress-track" data-progress="<%= Number(progressoMeta.percentual || 0) %>">
              <div class="progress-fill"></div>
            </div>
            <div style="font-size: 12px; color: var(--text-muted); margin-top: 8px;">
              <strong><%= Number(progressoMeta.percentual || 0).toFixed(1).replace('.', ',') %>%</strong> da meta de R$ <%= Number(metaEconomiaMensal || 0).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>
            </div>
          <% } else { %>
            <div style="font-size: 12px; color: var(--text-muted);">Defina uma meta para acompanhar sua evolucao mensal.</div>
          <% } %>
        </div>
      </div>
    </div>
  <% } %>

  <% if (temAcesso) { %>
    <form id="uploadForm" action="<%= appUrl %>/processar_upload.php" method="POST" enctype="multipart/form-data">
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>">
      <div id="dropzone" class="dropzone" tabindex="0" role="button" aria-label="Area de upload de arquivo">
        <label for="extrato" style="font-size: 17px; cursor: pointer;">Arraste seu arquivo aqui ou clique para selecionar</label>
        <p style="font-size: 13px; color: var(--text-muted); margin: 8px 0 0 0;">Formatos aceitos: PDF, CSV e XLSX</p>
        <input type="file" name="extrato" id="extrato" accept=".pdf,.csv,.xlsx" required style="position:absolute; opacity:0; pointer-events:none; width:1px; height:1px;">

        <div class="dropzone-meta" id="fileMeta">
          <span class="file-pill">Nenhum arquivo selecionado</span>
        </div>

        <div style="display: flex; justify-content: center; gap: 8px; margin-top: 14px; flex-wrap: wrap;">
          <button type="submit" id="submitBtn" class="btn" style="width: auto; min-width: 220px;">Enviar e Analisar via IA</button>
          <button type="button" id="clearFileBtn" class="btn btn-secondary" style="width: auto;">Limpar</button>
        </div>
      </div>

      <div id="loadingArea" class="soft-card soft-card-muted" style="display: none; margin-top: 12px; text-align: center;">
        <div class="chip chip-primary">Processando</div>
        <p style="margin: 10px 0 0 0; color: var(--text-muted);">Estamos analisando seu arquivo. Isso pode levar alguns segundos.</p>
      </div>
    </form>
  <% } else { %>
    <div style="border: 2px dashed var(--danger); padding: 40px; border-radius: 12px; margin-bottom: 20px; background: var(--card-bg); text-align: center;">
      <h3 style="color: var(--danger);">Seu limite gratuito acabou</h3>
      <p>Para continuar analisando seus gastos com IA, libere o acesso ilimitado.</p>
      <a href="<%= appUrl %>/planos.php" class="btn" style="background: var(--success); width: auto; margin-top: 15px;">Ver Planos e Assinar</a>
    </div>
  <% } %>
</div>

<script nonce="<%= cspNonce %>">
  document.querySelectorAll('.progress-track[data-progress]').forEach((progressTrack) => {
    const fill = progressTrack.querySelector('.progress-fill');
    const value = Number.parseFloat(progressTrack.getAttribute('data-progress') || '0');
    if (fill) {
      fill.style.width = `${Math.max(0, Math.min(100, value))}%`;
    }
  });

  const dropzone = document.getElementById('dropzone');
  const fileInput = document.getElementById('extrato');
  const fileMeta = document.getElementById('fileMeta');
  const clearFileBtn = document.getElementById('clearFileBtn');
  const uploadForm = document.getElementById('uploadForm');
  const submitBtn = document.getElementById('submitBtn');
  const loadingArea = document.getElementById('loadingArea');

  function renderFileMeta(file) {
    if (!fileMeta) return;
    if (!file) {
      fileMeta.innerHTML = '<span class="file-pill">Nenhum arquivo selecionado</span>';
      return;
    }

    const sizeMb = (file.size / (1024 * 1024)).toFixed(2);
    fileMeta.innerHTML = `<span class="file-pill">${file.name}</span><span class="file-pill">${sizeMb} MB</span>`;
  }

  if (dropzone && fileInput) {
    dropzone.addEventListener('click', (event) => {
      const interactiveTarget = event.target.closest('button, a, input, select, textarea, label, [role="button"]');
      if (interactiveTarget) {
        return;
      }

      fileInput.click();
    });
    dropzone.addEventListener('keydown', (event) => {
      if (event.target !== dropzone) {
        return;
      }

      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        fileInput.click();
      }
    });

    ['dragenter', 'dragover'].forEach((eventName) => {
      dropzone.addEventListener(eventName, (event) => {
        event.preventDefault();
        dropzone.classList.add('dragover');
      });
    });

    ['dragleave', 'drop'].forEach((eventName) => {
      dropzone.addEventListener(eventName, (event) => {
        event.preventDefault();
        dropzone.classList.remove('dragover');
      });
    });

    dropzone.addEventListener('drop', (event) => {
      const files = event.dataTransfer && event.dataTransfer.files;
      if (files && files.length > 0) {
        fileInput.files = files;
        renderFileMeta(files[0]);
      }
    });

    fileInput.addEventListener('change', () => {
      renderFileMeta(fileInput.files && fileInput.files[0]);
    });
  }

  if (clearFileBtn && fileInput) {
    clearFileBtn.addEventListener('click', () => {
      fileInput.value = '';
      renderFileMeta(null);
    });
  }

  if (uploadForm && submitBtn && loadingArea) {
    uploadForm.addEventListener('submit', () => {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando...';
      loadingArea.style.display = 'block';
    });
  }
</script>

<%- include('../partials/footer') %>
