<%- include('../partials/header') %>

<script nonce="<%= cspNonce %>" src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<div
  class="container"
  id="conteudo-pdf"
  data-chart-labels="<%= labelsChart %>"
  data-chart-values="<%= valoresChart %>"
  data-filename-stem="Diagnostico_Financeiro_<%= String(mesReferencia).replace('/', '_') %>"
>
  <div class="top-bar">
    <div>
      <h1 style="margin: 0;">Relatorio Financeiro - <%= mesReferencia %></h1>
      <div style="font-size: 13px; color: var(--text-muted); margin-top: 4px;">Analise consolidada com diagnostico, riscos e plano de acao.</div>
    </div>
    <div id="botoes-acao" style="display:flex; gap:10px; align-items:center;">
      <% if (isVisitante) { %>
        <a href="<%= appUrl %>/planos.php" class="btn" style="width: auto; background: var(--success); padding: 8px 15px;">Criar Conta</a>
      <% } else { %>
        <a href="<%= appUrl %>/historico.php" class="btn btn-secondary" style="width: auto; padding: 8px 15px;">Historico</a>
      <% } %>
      <button id="printReportBtn" class="btn btn-secondary" style="width: auto; padding: 8px 15px;">Imprimir</button>
      <button id="downloadPdfBtn" class="btn" style="width: auto; background: #333; padding: 8px 15px;">Baixar PDF</button>
    </div>
  </div>

  <div class="soft-card" style="margin-bottom: 18px;">
    <p class="section-title">Resumo Executivo</p>
    <div class="grid-3">
      <div class="soft-card soft-card-muted">
        <div class="kpi-label">Saldo mensal</div>
        <div class="kpi-value <%= saldoFinal >= 0 ? 'saldo-final-positivo' : 'saldo-final-negativo' %>">R$ <%= saldoFinal.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>
      </div>
      <div class="soft-card soft-card-muted">
        <div class="kpi-label">Score financeiro</div>
        <div class="kpi-value"><%= scoreSaude %>/100</div>
        <% if (faixaSaude === 'Excelente') { %>
          <span class="chip chip-success"><%= faixaSaude %></span>
        <% } else if (faixaSaude === 'Estavel') { %>
          <span class="chip chip-primary"><%= faixaSaude %></span>
        <% } else if (faixaSaude === 'Atencao') { %>
          <span class="chip chip-warning"><%= faixaSaude %></span>
        <% } else { %>
          <span class="chip chip-danger"><%= faixaSaude %></span>
        <% } %>
      </div>
      <div class="soft-card soft-card-muted">
        <div class="kpi-label">Economia potencial</div>
        <div class="kpi-value">R$ <%= economiaPotencial.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>
        <div style="font-size: 12px; color: var(--text-muted); margin-top: 4px;">Reducao estimada de 10% na principal categoria de gastos.</div>
      </div>
    </div>
  </div>

  <% if (comparativoMensal) { %>
    <div class="soft-card" style="margin-bottom: 18px;">
      <p class="section-title">Comparativo Mensal (<%= comparativoMensal.periodoAnterior %> vs <%= comparativoMensal.periodoAtual %>)</p>
      <div class="grid-3">
        <div class="soft-card soft-card-muted">
          <div class="kpi-label">Saldo mes atual</div>
          <div class="kpi-value <%= comparativoMensal.atual.saldo >= 0 ? 'saldo-final-positivo' : 'saldo-final-negativo' %>" style="font-size: 18px;">R$ <%= Number(comparativoMensal.atual.saldo || 0).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>
        </div>
        <div class="soft-card soft-card-muted">
          <div class="kpi-label">Saldo mes anterior</div>
          <div class="kpi-value <%= comparativoMensal.anterior.saldo >= 0 ? 'saldo-final-positivo' : 'saldo-final-negativo' %>" style="font-size: 18px;">R$ <%= Number(comparativoMensal.anterior.saldo || 0).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>
        </div>
        <div class="soft-card soft-card-muted">
          <div class="kpi-label">Variacao de saldo</div>
          <div class="kpi-value <%= comparativoMensal.deltaSaldo >= 0 ? 'saldo-final-positivo' : 'saldo-final-negativo' %>" style="font-size: 18px;">R$ <%= Number(comparativoMensal.deltaSaldo || 0).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>
          <div style="font-size: 12px; color: var(--text-muted); margin-top: 4px;">
            <% if (comparativoMensal.variacaoSaldoPercentual === null) { %>
              Sem base no mes anterior para percentual.
            <% } else { %>
              <%= Number(comparativoMensal.variacaoSaldoPercentual).toFixed(1).replace('.', ',') %>%
            <% } %>
          </div>
        </div>
      </div>
    </div>
  <% } %>

  <div class="grid-4" style="margin-bottom: 18px;">
    <div class="soft-card">
      <div class="kpi-label">Total de entradas</div>
      <div class="kpi-value" style="color: var(--success);">R$ <%= totalEntradas.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>
    </div>
    <div class="soft-card">
      <div class="kpi-label">Total de saidas</div>
      <div class="kpi-value" style="color: var(--danger);">R$ <%= totalSaidas.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>
    </div>
    <div class="soft-card">
      <div class="kpi-label">Taxa de poupanca</div>
      <div class="kpi-value"><%= taxaPoupanca.toFixed(1).replace('.', ',') %>%</div>
    </div>
    <div class="soft-card">
      <div class="kpi-label">Comprometimento da renda</div>
      <div class="kpi-value"><%= comprometimentoRenda.toFixed(1).replace('.', ',') %>%</div>
    </div>
  </div>

  <div class="grid-2" style="margin-bottom: 18px;">
    <div class="soft-card">
      <p class="section-title">Saude Financeira</p>
      <div class="progress-track" style="height: 12px; margin-bottom: 10px;">
        <div class="progress-fill dynamic-width" data-width="<%= scoreSaude %>"></div>
      </div>
      <ul class="insights-list">
        <li>Transacoes no periodo: <strong><%= totalTransacoes %></strong></li>
        <li>Ticket medio de gasto: <strong>R$ <%= ticketMedioSaida.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></strong></li>
        <li>Relação entradas/saidas: <strong><%= runwayMeses.toFixed(2).replace('.', ',') %>x</strong></li>
        <li>Dependencia da principal categoria: <strong><%= dependenciaTopCategoria.toFixed(1).replace('.', ',') %>%</strong></li>
      </ul>
    </div>

    <div class="soft-card">
      <p class="section-title">Projecao Anual</p>
      <div class="grid-3">
        <div class="soft-card soft-card-muted">
          <div class="kpi-label">Entradas</div>
          <div style="font-size: 16px; font-weight: 700; color: var(--success);">R$ <%= projecaoAnualEntradas.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>
        </div>
        <div class="soft-card soft-card-muted">
          <div class="kpi-label">Saidas</div>
          <div style="font-size: 16px; font-weight: 700; color: var(--danger);">R$ <%= projecaoAnualSaidas.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>
        </div>
        <div class="soft-card soft-card-muted">
          <div class="kpi-label">Saldo</div>
          <div class="<%= projecaoAnualSaldo >= 0 ? 'saldo-final-positivo' : 'saldo-final-negativo' %>" style="font-size: 16px; font-weight: 700;">R$ <%= projecaoAnualSaldo.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="grid-2" style="margin-bottom: 18px;">
    <div class="soft-card">
      <p class="section-title">Distribuicao de Despesas</p>
      <div style="min-height:300px; position:relative; margin-bottom: 10px;"><canvas id="graficoDespesas"></canvas></div>
      <ul style="list-style:none; margin:0; padding:0;">
        <% gastosPorCategoria.forEach(([categoria, valor]) => { const percentual = totalSaidas > 0 ? (valor / totalSaidas) * 100 : 0; %>
          <li style="padding:8px 0; border-bottom: 1px solid #f1f1f1;">
            <div style="display:flex; justify-content:space-between; gap:8px; margin-bottom:6px;">
              <strong><%= categoria %></strong>
              <span>R$ <%= Number(valor).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></span>
            </div>
            <div class="progress-track" style="height: 8px;">
              <div class="progress-fill dynamic-width" data-width="<%= Math.max(2, Math.min(100, percentual)) %>"></div>
            </div>
          </li>
        <% }) %>
      </ul>
    </div>

    <div class="soft-card">
      <p class="section-title">Composicao de Entradas</p>
      <% if (entradasOrdenadas && entradasOrdenadas.length > 0) { %>
        <ul style="list-style:none; margin:0; padding:0;">
          <% entradasOrdenadas.forEach(([categoria, valor]) => { const percentual = totalEntradas > 0 ? (valor / totalEntradas) * 100 : 0; %>
            <li style="padding:8px 0; border-bottom: 1px solid #f1f1f1;">
              <div style="display:flex; justify-content:space-between; gap:8px; margin-bottom:6px;">
                <strong><%= categoria %></strong>
                <span>R$ <%= Number(valor).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></span>
              </div>
              <div class="progress-track" style="height: 8px;">
                <div class="progress-fill dynamic-width" data-width="<%= Math.max(2, Math.min(100, percentual)) %>"></div>
              </div>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <p style="color: var(--text-muted);">Nao foram identificadas entradas suficientes para detalhamento.</p>
      <% } %>
    </div>
  </div>

  <div class="grid-2" style="margin-bottom: 18px;">
    <div class="soft-card">
      <p class="section-title">Top Saidas</p>
      <% if (topSaidasDetalhes && topSaidasDetalhes.length > 0) { %>
        <div style="overflow-x: auto;">
          <table class="table-clean">
            <thead>
              <tr><th>Descricao</th><th>Categoria</th><th>Valor</th></tr>
            </thead>
            <tbody>
              <% topSaidasDetalhes.forEach((item) => { %>
                <tr>
                  <td><%= item.descricao %></td>
                  <td><%= item.categoria %></td>
                  <td style="color: var(--danger); font-weight: 700;">R$ <%= Number(item.valor).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p style="color: var(--text-muted);">Sem dados de saida para montar ranking.</p>
      <% } %>
    </div>

    <div class="soft-card">
      <p class="section-title">Top Entradas</p>
      <% if (topEntradasDetalhes && topEntradasDetalhes.length > 0) { %>
        <div style="overflow-x: auto;">
          <table class="table-clean">
            <thead>
              <tr><th>Descricao</th><th>Categoria</th><th>Valor</th></tr>
            </thead>
            <tbody>
              <% topEntradasDetalhes.forEach((item) => { %>
                <tr>
                  <td><%= item.descricao %></td>
                  <td><%= item.categoria %></td>
                  <td style="color: var(--success); font-weight: 700;">R$ <%= Number(item.valor).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p style="color: var(--text-muted);">Sem dados de entrada para montar ranking.</p>
      <% } %>
    </div>
  </div>

  <div class="grid-2">
    <div class="soft-card">
      <p class="section-title">Diagnostico Rapido</p>
      <ul class="insights-list">
        <% diagnosticoRapido.forEach((item) => { %>
          <li><%= item %></li>
        <% }) %>
      </ul>
    </div>

    <div class="soft-card" style="background: #f7fbff; border-color: #d8e8ff;">
      <p class="section-title">Plano de Acao Prioritario</p>
      <% if (dados.dicas && dados.dicas.length) { %>
        <ul class="insights-list">
          <% dados.dicas.forEach((dica, index) => { %>
            <li>
              <% if (index === 0) { %><span class="chip chip-danger">Alta prioridade</span><% } %>
              <% if (index === 1) { %><span class="chip chip-warning">Media prioridade</span><% } %>
              <% if (index > 1) { %><span class="chip chip-primary">Rotina</span><% } %>
              <div style="margin-top: 6px;"><%= dica %></div>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <p style="color: var(--text-muted);">Nenhuma dica disponivel neste relatorio.</p>
      <% } %>
    </div>
  </div>
</div>

<script nonce="<%= cspNonce %>">
  const reportContainer = document.getElementById('conteudo-pdf');
  const rawLabels = JSON.parse(reportContainer?.getAttribute('data-chart-labels') || '[]');
  const rawData = JSON.parse(reportContainer?.getAttribute('data-chart-values') || '[]');

  if (rawLabels.length > 0) {
    const ctx = document.getElementById('graficoDespesas').getContext('2d');
    new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels: rawLabels,
        datasets: [{
          data: rawData,
          backgroundColor: ['#FF6384','#36A2EB','#FFCE56','#4BC0C0','#9966FF','#FF9F40','#EA6A47','#A5D8DD','#5E92F3'],
          borderWidth: 2,
          borderColor: '#ffffff',
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom' } },
        cutout: '65%',
      },
    });
  }

  document.querySelectorAll('.dynamic-width[data-width]').forEach((element) => {
    const value = Number.parseFloat(element.getAttribute('data-width') || '0');
    element.style.width = `${Math.max(0, Math.min(100, value))}%`;
  });

  function gerarPDF() {
    const element = document.getElementById('conteudo-pdf');
    const filenameStem = element?.getAttribute('data-filename-stem') || 'Diagnostico_Financeiro';
    html2pdf().set({
      margin: 10,
      filename: `${filenameStem}.pdf`,
      image: { type: 'jpeg', quality: 0.98 },
      html2canvas: { scale: 2, useCORS: true },
      jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' },
    }).from(element).save();
  }

  const printReportBtn = document.getElementById('printReportBtn');
  if (printReportBtn) {
    printReportBtn.addEventListener('click', () => {
      window.print();
    });
  }

  const downloadPdfBtn = document.getElementById('downloadPdfBtn');
  if (downloadPdfBtn) {
    downloadPdfBtn.addEventListener('click', () => {
      gerarPDF();
    });
  }
</script>

<style>
  .saldo-final-positivo { color: var(--success); }
  .saldo-final-negativo { color: var(--danger); }
</style>

<%- include('../partials/footer') %>
